model ProductionOrder {
  id           BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  orderRef     String?               @map("order_ref") @db.VarChar(100)
  issuedAt     DateTime              @default(now()) @map("issued_at")
  skuProductId BigInt?               @map("sku_product_id") @db.UnsignedBigInt
  skuCode      String?               @map("sku_code") @db.VarChar(100)
  skuName      String?               @map("sku_name") @db.VarChar(255)
  productType  String?               @map("product_type") @db.VarChar(100)
  currentStep  Int                   @default(1) @map("current_step") @db.TinyInt
  status       ProductionOrderStatus @default(draft)
  notes        String?               @db.Text
  createdBy    BigInt                @map("created_by") @db.UnsignedBigInt
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  outputProductId BigInt?              @map("output_product_id") @db.UnsignedBigInt
  nvlExportedAt   DateTime?            @map("nvl_exported_at")
  step1ProcessedAt DateTime?           @map("step1_processed_at")
  step2ProcessedAt DateTime?           @map("step2_processed_at")
  step3ProcessedAt DateTime?           @map("step3_processed_at")
  step4ProcessedAt DateTime?           @map("step4_processed_at")
  creator         User                  @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  skuProduct      Product?              @relation(fields: [skuProductId], references: [id], onDelete: SetNull)
  outputProduct   ProductOutput?        @relation(fields: [outputProductId], references: [id], onDelete: SetNull)
  lines           ProductionOrderLine[]
  logs            ProductionOrderLog[]
  outputTransactions ProductionOutputTransaction[]
  nvlInventoryTransactions InventoryTransaction[] @relation("ProductionOrderNvlTransactions")

  @@index([status])
  @@index([issuedAt])
  @@index([skuProductId])
  @@index([outputProductId])
  @@map("production_orders")
}

// ─── Production order detail lines (BOM per step) ─────────────────────────────
// step 1: xuất NVL (direction=out, location=kho NVL)
// step 2: nhập BTP (direction=in,  location=kho BTP)
// step 3: xuất BTP (direction=out, location=kho BTP)
// step 4: nhập TP  (direction=in,  location=kho TP)
model ProductionOrderLine {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  orderId     BigInt   @map("order_id") @db.UnsignedBigInt
  step        Int      @db.TinyInt
  direction   String   @db.VarChar(3)       // 'out' | 'in'
  productId       BigInt?  @map("product_id") @db.UnsignedBigInt
  outputProductId BigInt?  @map("output_product_id") @db.UnsignedBigInt
  productCode     String   @map("product_code") @db.VarChar(100)
  productName     String   @map("product_name") @db.VarChar(255)
  lotNo       String?  @map("lot_no") @db.VarChar(100)
  expiryDate  DateTime? @map("expiry_date") @db.Date
  exportDate  DateTime? @map("export_date")
  plannedQty  Decimal  @default(0) @map("planned_qty") @db.Decimal(15, 4)
  actualQty   Decimal  @default(0) @map("actual_qty") @db.Decimal(15, 4)
  wasteQty    Decimal  @default(0) @map("waste_qty") @db.Decimal(15, 4)
  unit        String   @db.VarChar(50)
  locationId  BigInt?  @map("location_id") @db.UnsignedBigInt
  qualityStatus String? @map("quality_status") @db.VarChar(20) // pass|fail|pending (step 4)
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  order         ProductionOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  outputProduct ProductOutput?   @relation(fields: [outputProductId], references: [id], onDelete: SetNull)
  location      CatalogLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([orderId, step])
  @@map("production_order_lines")
}

model ProductionOrderLog {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  orderId   BigInt   @map("order_id") @db.UnsignedBigInt
  userId    BigInt?  @map("user_id") @db.UnsignedBigInt
  userName  String?  @map("user_name") @db.VarChar(191)
  action    String   @db.VarChar(500)
  logType   String   @default("system") @map("log_type") @db.VarChar(20)
  step      Int?     @db.UnsignedTinyInt
  createdAt DateTime @default(now()) @map("created_at")
  order     ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("production_order_logs")
}

model ProductionOutputTransaction {
  id                   BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  productionOrderId    BigInt?  @map("production_order_id") @db.UnsignedBigInt
  tpExportOrderId      BigInt?  @map("tp_export_order_id") @db.UnsignedBigInt
  outputProductId      BigInt   @map("output_product_id") @db.UnsignedBigInt
  type                 ProductionOutputTransactionType
  quantityBase         Decimal  @map("quantity_base") @db.Decimal(15, 4)
  warehouseLocationId  BigInt?  @map("warehouse_location_id") @db.UnsignedBigInt
  batchLotNo           String   @map("batch_lot_no") @db.VarChar(100) @default("")
  batchExpiryDate      DateTime? @map("batch_expiry_date") @db.Date
  userId               BigInt?  @map("user_id") @db.UnsignedBigInt
  notes                String?  @db.Text
  transactionDate      DateTime @default(now()) @map("transaction_date")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  order                ProductionOrder?    @relation(fields: [productionOrderId], references: [id], onDelete: SetNull)
  tpExportOrder        TpExportOrder?      @relation("TpExportOutputTransactions", fields: [tpExportOrderId], references: [id], onDelete: SetNull)
  outputProduct        ProductOutput       @relation(fields: [outputProductId], references: [id], onDelete: Restrict)
  warehouseLocation    CatalogLocation?    @relation(fields: [warehouseLocationId], references: [id], onDelete: SetNull)
  user                 User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productionOrderId])
  @@index([tpExportOrderId])
  @@index([outputProductId, transactionDate, type])
  @@map("production_output_transactions")
}

model PasswordResetToken {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  token     String    @unique @db.VarChar(191)
  userId    BigInt    @map("user_id") @db.UnsignedBigInt
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}
