generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProductDocType {
  MSDS
  Spec
  Other
}

enum BatchStatus {
  available
  quarantine
  rejected
  expired
}

enum BatchDocType {
  Invoice
  COA
  Other
}

enum OpeningStockDocType {
  Invoice
  COA
  MSDS
  Other
}

enum ExportOrderStatus {
  pending
  fulfilled
  cancelled
}

enum ProductionOrderStatus {
  draft
  in_progress
  completed
  cancelled
}

enum ProductOutputType {
  finished
  semi_finished
}

enum InventoryTransactionType {
  import
  export
  adjustment
}

enum ProductionOutputTransactionType {
  import_from_production
  export_to_sale
  adjustment
}

enum PurchaseRequestStatus {
  draft
  submitted
  approved
  ordered
  partially_received
  received
  cancelled
}

enum InboundReceiptStatus {
  draft
  pending_qc
  posted
  cancelled
}

enum InboundReceiptItemQcStatus {
  pending
  passed
  failed
}

enum InboundReceiptItemDocType {
  Invoice
  COA
  MSDS
  Other
}

enum OpeningStockDeclarationStatus {
  draft
  posted
  cancelled
}

enum OpeningStockSource {
  manual
  excel
}

enum OpeningStockPostingStatus {
  draft
  posted
  failed
}

model User {
  id           BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  email        String           @unique @db.VarChar(191)
  passwordHash String           @map("password_hash") @db.VarChar(255)
  fullName     String           @map("full_name") @db.VarChar(191)
  role         String           @default("warehouse_staff") @db.VarChar(50)
  isActive     Boolean          @default(true) @map("is_active")
  deletedAt    DateTime?        @map("deleted_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  productDocuments ProductDocument[]
  batchDocuments   BatchDocument[]
  openingStockItemDocuments OpeningStockItemDocument[]
  inboundReceiptItemDocuments InboundReceiptItemDocument[]
  exportOrders     ExportOrder[]
  productionOrders ProductionOrder[]
  productionOrderLogs  ProductionOrderLog[]
  inventoryTransactions InventoryTransaction[]
  outputTransactions ProductionOutputTransaction[]
  requestedPurchaseRequests PurchaseRequest[] @relation("PurchaseRequestRequestedBy")
  approvedPurchaseRequests  PurchaseRequest[] @relation("PurchaseRequestApprovedBy")
  createdInboundReceipts InboundReceipt[] @relation("InboundReceiptCreatedBy")
  postedInboundReceipts InboundReceipt[] @relation("InboundReceiptPostedBy")
  inboundReceiptHistoryEntries InboundReceiptHistory[] @relation("InboundReceiptHistoryActor")
  exportOrderHistoryEntries ExportOrderHistory[] @relation("ExportOrderHistoryActor")
  tpExportOrders            TpExportOrder[]      @relation("TpExportOrderCreator")
  tpExportOrderHistoryEntries TpExportOrderHistory[] @relation("TpExportOrderHistoryActor")
  createdOpeningStockDeclarations OpeningStockDeclaration[] @relation("OpeningStockCreatedBy")
  postedOpeningStockDeclarations  OpeningStockDeclaration[] @relation("OpeningStockPostedBy")
  notifications Notification[]

  @@map("users")
}

model Product {
  id             BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  code           String           @unique @db.VarChar(100)
  name           String           @db.VarChar(255)
  inciName       String?          @map("inci_name") @db.VarChar(255)
  productType    BigInt?          @map("product_type") @db.UnsignedBigInt
  hasExpiry      Boolean          @default(true) @map("has_expiry")
  useFefo        Boolean          @default(true) @map("use_fefo")
  baseUnit       BigInt           @map("base_unit") @db.UnsignedBigInt
  orderUnit      BigInt?          @map("order_unit") @db.UnsignedBigInt
  minStockLevel  Decimal          @default(0) @map("min_stock_level") @db.Decimal(15, 4)
  notes          String?          @db.Text
  deletedAt      DateTime?        @map("deleted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  productUnits   ProductUnit[]    @relation("ProductUnitsByProduct")
  baseUnitRef    ProductUnit      @relation("ProductBaseUnit", fields: [baseUnit], references: [id], onDelete: Restrict)
  orderUnitRef   ProductUnit?     @relation("ProductOrderUnit", fields: [orderUnit], references: [id], onDelete: SetNull)
  productDocuments ProductDocument[]
  batches        Batch[]
  exportOrderItems ExportOrderItem[]
  purchaseRequestItems PurchaseRequestItem[]
  inboundReceiptItems InboundReceiptItem[]
  openingStockItems OpeningStockItem[]
  productClassification ProductClassification? @relation(fields: [productType], references: [id], onDelete: SetNull)
  inciNames        ProductInciName[]
  manufacturers    ProductManufacturer[]
  productSuppliers ProductSupplier[]
  productionOrders ProductionOrder[]
  productionOrderLines ProductionOrderLine[]

  @@map("products")
}

model ProductUnit {
  id               BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  productId        BigInt?      @map("product_id") @db.UnsignedBigInt
  parentUnitId     BigInt?      @map("parent_unit_id") @db.UnsignedBigInt
  unitCodeName     String?      @map("unit_code_name") @db.VarChar(100)
  unitName         String       @map("unit_name") @db.VarChar(100)
  unitMemo         String?      @map("unit_memo") @db.VarChar(255)
  conversionToBase Decimal      @map("conversion_to_base") @db.Decimal(15, 4)
  isPurchaseUnit   Boolean      @default(false) @map("is_purchase_unit")
  isDefaultDisplay Boolean      @default(false) @map("is_default_display")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  product          Product?     @relation("ProductUnitsByProduct", fields: [productId], references: [id], onDelete: Cascade)
  parentUnit       ProductUnit? @relation("ProductUnitHierarchy", fields: [parentUnitId], references: [id])
  childUnits       ProductUnit[] @relation("ProductUnitHierarchy")
  productsAsBaseUnit Product[]  @relation("ProductBaseUnit")
  productsAsOrderUnit Product[] @relation("ProductOrderUnit")
  openingStockPriceItems OpeningStockItem[]

  @@unique([productId, unitName])
  @@map("product_units")
}

model ProductDocument {
  id           BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  productId    BigInt         @map("product_id") @db.UnsignedBigInt
  docType      ProductDocType @map("doc_type")
  filePath     String         @map("file_path") @db.VarChar(500)
  originalName String         @map("original_name") @db.VarChar(255)
  fileSize     BigInt?        @map("file_size") @db.UnsignedBigInt
  uploadedBy   BigInt         @map("uploaded_by") @db.UnsignedBigInt
  validUntil   DateTime?      @map("valid_until") @db.Date
  notes        String?        @db.Text
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  uploader     User           @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@map("product_documents")
}

model Supplier {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  code        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(255)
  phone       String?  @db.VarChar(50)
  contactInfo String?  @map("contact_info") @db.VarChar(255)
  address     String?  @db.VarChar(255)
  notes       String?  @db.Text
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  batches     Batch[]
  purchaseRequests PurchaseRequest[]
  inboundReceipts InboundReceipt[]
  openingStockItems OpeningStockItem[]
  productSuppliers ProductSupplier[]

  @@map("suppliers")
}

model Customer {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  code      String    @unique @db.VarChar(100)
  name      String    @db.VarChar(255)
  phone     String?   @db.VarChar(50)
  email     String?   @db.VarChar(191)
  address   String?   @db.VarChar(255)
  notes     String?   @db.Text
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  exportOrders   ExportOrder[]
  tpExportOrders TpExportOrder[] @relation("TpExportOrderCustomer")

  @@map("customers")
}

model Batch {
  id               BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  productId        BigInt      @map("product_id") @db.UnsignedBigInt
  supplierId       BigInt?     @map("supplier_id") @db.UnsignedBigInt
  inboundReceiptItemId BigInt? @map("inbound_receipt_item_id") @db.UnsignedBigInt
  lotNo            String      @map("lot_no") @db.VarChar(100)
  invoiceNumber    String?     @map("invoice_number") @db.VarChar(100)
  invoiceDate      DateTime?   @map("invoice_date") @db.Date
  unitPricePerKg   Decimal     @default(0) @map("unit_price_per_kg") @db.Decimal(15, 2)
  receivedQtyBase  Decimal     @map("received_qty_base") @db.Decimal(15, 4)
  currentQtyBase   Decimal     @default(0) @map("current_qty_base") @db.Decimal(15, 4)
  purchaseUnit     String?     @map("purchase_unit") @db.VarChar(50)
  purchaseQty      Decimal?    @map("purchase_qty") @db.Decimal(15, 4)
  manufactureDate  DateTime?   @map("manufacture_date") @db.Date
  expiryDate       DateTime?   @map("expiry_date") @db.Date
  manufacturerId   BigInt?     @map("manufacturer_id") @db.UnsignedBigInt
  status           BatchStatus @default(available)
  notes            String?     @db.Text
  deletedAt        DateTime?   @map("deleted_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  product          Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplier         Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  manufacturer     ProductManufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  inboundReceiptItemSource InboundReceiptItem? @relation("InboundReceiptItemSourceBatch", fields: [inboundReceiptItemId], references: [id], onDelete: SetNull)
  batchDocuments   BatchDocument[]
  exportOrderItems ExportOrderItem[]
  postedInboundReceiptItems InboundReceiptItem[] @relation("InboundReceiptPostedBatch")
  inventoryTransactions InventoryTransaction[]

  @@index([productId, status, expiryDate])
  @@index([inboundReceiptItemId])
  @@map("batches")
}

model BatchDocument {
  id           BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  batchId       BigInt      @map("batch_id") @db.UnsignedBigInt
  docType       BatchDocType @map("doc_type")
  filePath      String      @map("file_path") @db.VarChar(500)
  originalName  String      @map("original_name") @db.VarChar(255)
  mimeType      String      @map("mime_type") @db.VarChar(100)
  fileSize      BigInt      @map("file_size") @db.UnsignedBigInt
  uploadedBy    BigInt      @map("uploaded_by") @db.UnsignedBigInt
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  batch         Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  uploader      User        @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@map("batch_documents")
}

model ExportOrder {
  id                BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  customerId        BigInt?           @map("customer_id") @db.UnsignedBigInt
  sourceOrderId     BigInt?           @map("source_order_id") @db.UnsignedBigInt
  adjustedByOrderId BigInt?           @map("adjusted_by_order_id") @db.UnsignedBigInt
  sourceLocationId  BigInt?           @map("source_location_id") @db.UnsignedBigInt
  orderRef          String?           @map("order_ref") @db.VarChar(100)
  exportedAt        DateTime?         @map("exported_at")
  createdBy         BigInt            @map("created_by") @db.UnsignedBigInt
  status            ExportOrderStatus @default(pending)
  notes             String?           @db.Text
  dienGiai          String?           @map("Dien_giai") @db.Text
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  customer          Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sourceOrder       ExportOrder?      @relation("ExportOrderAdjustmentSource", fields: [sourceOrderId], references: [id], onDelete: SetNull)
  adjustedByOrder   ExportOrder?      @relation("ExportOrderAdjustmentTarget", fields: [adjustedByOrderId], references: [id], onDelete: SetNull)
  adjustmentOrders  ExportOrder[]     @relation("ExportOrderAdjustmentSource")
  adjustedOrders    ExportOrder[]     @relation("ExportOrderAdjustmentTarget")
  sourceLocation    CatalogLocation?  @relation("ExportOrderSourceLocation", fields: [sourceLocationId], references: [id], onDelete: SetNull)
  creator           User              @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  items             ExportOrderItem[]
  purchaseRequests  PurchaseRequest[]
  historyEntries    ExportOrderHistory[]

  @@index([sourceOrderId])
  @@index([adjustedByOrderId])
  @@index([sourceLocationId])
  @@unique([sourceOrderId])
  @@unique([adjustedByOrderId])
  @@map("export_orders")
}

model ExportOrderHistory {
  id             BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  exportOrderId  BigInt      @map("export_order_id") @db.UnsignedBigInt
  actionType     String      @map("action_type") @db.VarChar(100)
  actionLabel    String      @map("action_label") @db.VarChar(255)
  actorId        BigInt      @map("actor_id") @db.UnsignedBigInt
  data           Json?
  createdAt      DateTime    @default(now()) @map("created_at")
  exportOrder    ExportOrder @relation(fields: [exportOrderId], references: [id], onDelete: Cascade)
  actor          User        @relation("ExportOrderHistoryActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([exportOrderId])
  @@index([createdAt])
  @@map("export_order_history")
}

model ExportOrderItem {
  id                BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  exportOrderId     BigInt            @map("export_order_id") @db.UnsignedBigInt
  batchId           BigInt?           @map("batch_id") @db.UnsignedBigInt
  productId         BigInt            @map("product_id") @db.UnsignedBigInt
  quantityBase      Decimal           @map("quantity_base") @db.Decimal(15, 4)
  unitUsed          String            @map("unit_used") @db.VarChar(50)
  quantityDisplay   Decimal           @map("quantity_display") @db.Decimal(15, 4)
  unitPriceSnapshot Decimal           @default(0) @map("unit_price_snapshot") @db.Decimal(15, 2)
  status            ExportOrderStatus @default(pending)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  exportOrder       ExportOrder       @relation(fields: [exportOrderId], references: [id], onDelete: Cascade)
  batch             Batch?            @relation(fields: [batchId], references: [id], onDelete: SetNull)
  product           Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryTransactions InventoryTransaction[]
  purchaseRequestItems PurchaseRequestItem[]

  @@map("export_order_items")
}

model InventoryTransaction {
  id                   BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  batchId              BigInt                   @map("batch_id") @db.UnsignedBigInt
  userId               BigInt                   @map("user_id") @db.UnsignedBigInt
  exportOrderItemId    BigInt?                  @map("export_order_item_id") @db.UnsignedBigInt
  inboundReceiptItemId BigInt?                  @map("inbound_receipt_item_id") @db.UnsignedBigInt
  productionOrderId    BigInt?                  @map("production_order_id") @db.UnsignedBigInt
  warehouseLocationId  BigInt                   @map("warehouse_location_id") @db.UnsignedBigInt
  type                 InventoryTransactionType
  quantityBase         Decimal                  @map("quantity_base") @db.Decimal(15, 4)
  notes                String?                  @db.Text
  isCancelled          Boolean                  @default(false) @map("is_cancelled")
  transactionDate      DateTime                 @map("transaction_date")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")
  batch                Batch                    @relation(fields: [batchId], references: [id], onDelete: Restrict)
  user                 User                     @relation(fields: [userId], references: [id], onDelete: Restrict)
  exportOrderItem      ExportOrderItem?         @relation(fields: [exportOrderItemId], references: [id], onDelete: SetNull)
  inboundReceiptItemSource InboundReceiptItem?  @relation("InboundReceiptItemSourceTransaction", fields: [inboundReceiptItemId], references: [id], onDelete: SetNull)
  postedInboundReceiptItems InboundReceiptItem[] @relation("InboundReceiptPostedTransaction")
  productionOrder      ProductionOrder?         @relation("ProductionOrderNvlTransactions", fields: [productionOrderId], references: [id], onDelete: SetNull)
  warehouseLocation    CatalogLocation          @relation("InventoryTransactionLocation", fields: [warehouseLocationId], references: [id], onDelete: Restrict)

  @@index([inboundReceiptItemId])
  @@index([batchId, transactionDate, type])
  @@index([productionOrderId])
  @@index([warehouseLocationId])
  @@map("inventory_transactions")
}

model PurchaseRequest {
  id            BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  exportOrderId BigInt?              @map("export_order_id") @db.UnsignedBigInt
  requestRef    String               @unique @map("request_ref") @db.VarChar(100)
  requestedBy   BigInt               @map("requested_by") @db.UnsignedBigInt
  approvedBy    BigInt?              @map("approved_by") @db.UnsignedBigInt
  supplierId    BigInt?              @map("supplier_id") @db.UnsignedBigInt
  receivingLocationId BigInt?        @map("receiving_location_id") @db.UnsignedBigInt
  status        PurchaseRequestStatus @default(draft)
  expectedDate  DateTime?            @map("expected_date") @db.Date
  notes         String?              @db.Text
  dienGiai      String?              @map("Dien_giai") @db.Text
  submittedAt   DateTime?            @map("submitted_at")
  approvedAt    DateTime?            @map("approved_at")
  orderedAt     DateTime?            @map("ordered_at")
  receivedAt    DateTime?            @map("received_at")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  exportOrder   ExportOrder?         @relation(fields: [exportOrderId], references: [id], onDelete: SetNull)
  requester     User                 @relation("PurchaseRequestRequestedBy", fields: [requestedBy], references: [id], onDelete: Restrict)
  approver      User?                @relation("PurchaseRequestApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  supplier      Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  receivingLocation CatalogLocation? @relation("PurchaseRequestReceivingLocation", fields: [receivingLocationId], references: [id], onDelete: SetNull)
  items         PurchaseRequestItem[]
  inboundReceipts InboundReceipt[]

  @@index([status])
  @@index([exportOrderId])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                 BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  purchaseRequestId   BigInt           @map("purchase_request_id") @db.UnsignedBigInt
  productId           BigInt           @map("product_id") @db.UnsignedBigInt
  exportOrderItemId   BigInt?          @map("export_order_item_id") @db.UnsignedBigInt
  quantityNeededBase  Decimal          @map("quantity_needed_base") @db.Decimal(15, 4)
  receivedQtyBase     Decimal          @default(0) @map("received_qty_base") @db.Decimal(15, 4)
  unitDisplay         String           @map("unit_display") @db.VarChar(50)
  quantityDisplay     Decimal          @map("quantity_display") @db.Decimal(15, 4)
  unitPrice           Decimal          @default(0) @map("unit_price") @db.Decimal(15, 2)
  notes               String?          @db.Text
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  purchaseRequest     PurchaseRequest  @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  product             Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  exportOrderItem     ExportOrderItem? @relation(fields: [exportOrderItemId], references: [id], onDelete: SetNull)
  inboundReceiptItems InboundReceiptItem[]

  @@map("purchase_request_items")
}

model Notification {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt    @map("user_id") @db.UnsignedBigInt
  type      String    @db.VarChar(100)
  data      Json
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ProductClassification {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  code      String    @unique @db.VarChar(100)
  name      String    @db.VarChar(255)
  notes     String?   @db.Text
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]

  @@map("product_classifications")
}

model CatalogLocation {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  code      String    @unique @db.VarChar(100)
  name      String    @db.VarChar(255)
  notes     String?   @db.Text
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  openingStockItems OpeningStockItem[]
  purchaseRequests PurchaseRequest[] @relation("PurchaseRequestReceivingLocation")
  inboundReceipts InboundReceipt[] @relation("InboundReceiptReceivingLocation")
  exportOrders   ExportOrder[]   @relation("ExportOrderSourceLocation")
  tpExportOrders TpExportOrder[] @relation("TpExportOrderSourceLocation")
  productionOrderLines ProductionOrderLine[]
  outputTransactions ProductionOutputTransaction[]
  inventoryTransactions InventoryTransaction[] @relation("InventoryTransactionLocation")

  @@map("inventory_locations")
}

model InboundReceipt {
  id                 BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  receiptRef         String                @unique @map("receipt_ref") @db.VarChar(100)
  purchaseRequestId  BigInt?               @map("purchase_request_id") @db.UnsignedBigInt
  sourceReceiptId    BigInt?               @map("source_receipt_id") @db.UnsignedBigInt
  adjustedByReceiptId BigInt?              @map("adjusted_by_receipt_id") @db.UnsignedBigInt
  supplierId         BigInt?               @map("supplier_id") @db.UnsignedBigInt
  receivingLocationId BigInt?              @map("receiving_location_id") @db.UnsignedBigInt
  status             InboundReceiptStatus  @default(draft)
  expectedDate       DateTime?             @map("expected_date") @db.Date
  receivedAt         DateTime?             @map("received_at")
  qcCheckedAt        DateTime?             @map("qc_checked_at")
  currentStep        Int                   @default(2) @map("current_step") @db.UnsignedTinyInt
  createdBy          BigInt                @map("created_by") @db.UnsignedBigInt
  postedBy           BigInt?               @map("posted_by") @db.UnsignedBigInt
  notes              String?               @db.Text
  dienGiai           String?               @map("Dien_giai") @db.Text
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  purchaseRequest    PurchaseRequest?      @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  supplier           Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  receivingLocation  CatalogLocation?      @relation("InboundReceiptReceivingLocation", fields: [receivingLocationId], references: [id], onDelete: SetNull)
  creator            User                  @relation("InboundReceiptCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  poster             User?                 @relation("InboundReceiptPostedBy", fields: [postedBy], references: [id], onDelete: SetNull)
  sourceReceipt      InboundReceipt?       @relation("InboundReceiptAdjustmentSource", fields: [sourceReceiptId], references: [id], onDelete: SetNull)
  adjustedByReceipt  InboundReceipt?       @relation("InboundReceiptAdjustmentTarget", fields: [adjustedByReceiptId], references: [id], onDelete: SetNull)
  adjustmentReceipts InboundReceipt[]      @relation("InboundReceiptAdjustmentSource")
  adjustedReceipts   InboundReceipt[]      @relation("InboundReceiptAdjustmentTarget")
  items              InboundReceiptItem[]
  historyEntries     InboundReceiptHistory[]

  @@index([status])
  @@index([purchaseRequestId])
  @@index([sourceReceiptId])
  @@index([adjustedByReceiptId])
  @@unique([sourceReceiptId])
  @@unique([adjustedByReceiptId])
  @@index([supplierId])
  @@index([receivingLocationId])
  @@map("inbound_receipts")
}

model InboundReceiptItem {
  id                    BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  inboundReceiptId      BigInt                     @map("inbound_receipt_id") @db.UnsignedBigInt
  purchaseRequestItemId BigInt?                    @map("purchase_request_item_id") @db.UnsignedBigInt
  productId             BigInt                     @map("product_id") @db.UnsignedBigInt
