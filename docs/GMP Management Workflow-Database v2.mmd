erDiagram
  %% USERS & ROLES
  USERS {
    int id PK
    string email
    string username
    string full_name
    string password_hash
    string phone
    string status
    datetime last_login
    datetime created_at
    int created_by
    datetime updated_at
    int updated_by
    bool is_deleted
  }

  ROLES {
    int id PK
    string code
    string name
    string description
    datetime created_at
    int created_by
  }

  USER_ROLES {
    int id PK
    int user_id FK
    int role_id FK
    datetime assigned_at
    int assigned_by
  }

  %% PRODUCTS & R&D
  PRODUCTS {
    int id PK
    string product_code
    string product_name
