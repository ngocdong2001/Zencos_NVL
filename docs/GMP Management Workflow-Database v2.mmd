    int uom_id FK
    string pack_size
    string spec_version
    string status
    text description
    datetime created_at
    int created_by
    datetime updated_at
    int updated_by
    bool is_deleted
  }

  PRODUCT_SPECS {
    int id PK
    int product_id FK
    string spec_name
    float min_value
    float max_value
    string unit
    text method_reference
    datetime created_at
  }

  FORMULATIONS {
    int id PK
    string formula_code
    int product_id FK
    string version
    string status
    int approved_by
    datetime approved_at
    text notes
    datetime created_at
    int created_by
  }

  FORMULA_ITEMS {
    int id PK
    int formula_id FK
    int material_id FK
